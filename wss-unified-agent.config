# Mend agent config for omnisharp-roslyn

# Mend documentation: https://docs.mend.io/en-US/bundle/unified_agent/page/getting_started_with_the_unified_agent.html

# Exclude tests - only scan product code
excludes=tests/** test-assets/**
fileSystemScan=False
resolveAllDependencies=False

maven.aggregateModules=True
maven.downloadMissingDependencies=False
maven.resolveDependencies=True
maven.runPreStep=False

nuget.resolvePackagesConfigFiles=True
nuget.resolveDependencies=True
nuget.preferredEnvironment=dotnet
nuget.runPreStep=True

wss.url=https://saas-eu.whitesourcesoftware.com/agent

forceUpdate=true
checkPolicies=true
forceUpdate.failBuildOnPolicyViolation=false
